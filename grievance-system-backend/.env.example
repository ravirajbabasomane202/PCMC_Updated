# ─────────────────────────────────────────────────────────
#  PCMC Grievance System — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────

APP_ENV=production        # development | production | testing

# Security keys — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-random-hex-32
JWT_SECRET_KEY=replace-with-another-random-hex-32
SECURITY_PASSWORD_SALT=replace-with-random-hex-16
RESET_TOKEN_SECRET=replace-with-random-hex-16

# Database (PostgreSQL recommended for production)
DATABASE_URL=postgresql://postgres:ravi@localhost:5432/grievance_db
# For local SQLite dev: DATABASE_URL=sqlite:///dev.db

# Redis (optional — improves rate-limit accuracy across multiple workers)
# REDIS_URL=redis://localhost:6379/0

# Email (Gmail App Password recommended — NOT your account password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Google OAuth (OPTIONAL — leave blank to disable Google login entirely)
# To enable: create credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend URL (used for Google OAuth redirect and password-reset links)
FRONTEND_CALLBACK_URL=https://www.nivaran.co.in

# CORS origins (comma-separated, leave unset to use defaults in config.py)
# CORS_ORIGINS=https://www.nivaran.co.in,https://pcmcapp.onrender.com

# Twilio (for OTP SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
